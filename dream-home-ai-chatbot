from groq import Groq


client = Groq(api_key="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")

print("Chatbot (Groq Streaming)")
print("Type 'quit', 'exit', or 'bye' to stop.\n")

while True:

